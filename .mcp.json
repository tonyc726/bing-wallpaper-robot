{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "Ant Design Components": {
      "command": "npx",
      "args": [
        "@jzone-mcp/antd-components-mcp"
      ]
    }
  }
}
