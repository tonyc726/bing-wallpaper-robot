{
  "name": "bing-wallpaper-robot",
  "version": "1.2.20",
  "description": "Daily updated, compacted metadata chunks of Bing Wallpapers",
  "private": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "main": "docs/index.js",
  "exports": {
    ".": "./docs/index.js",
    "./chunks/*": "./docs/chunks/*",
    "./utils.js": "./docs/utils.js"
  },
  "files": [
    "docs/chunks/*.js",
    "docs/*.js",
    "docs/*.json"
  ],
  "scripts": {
    "typeorm": "node --require ts-node/register ./node_modules/typeorm/cli.js",
    "migration:generate": "node --require ts-node/register ./node_modules/typeorm/cli.js migration:generate -p -n",
    "migration:run": "node --require ts-node/register ./node_modules/typeorm/cli.js migration:run",
    "run-migration": "node --require ts-node/register ./crawler/tyorm-run-migration.ts",
    "migration:revert": "node --require ts-node/register ./node_modules/typeorm/cli.js migration:revert",
    "fetch-data": "node --require ts-node/register ./crawler/index.ts",
    "build:data": "node --require ts-node/register ./crawler/makePreviewJSON.ts",
    "build:frontend": "cd website && pnpm install --frozen-lockfile && pnpm run build",
    "build:copy": "node scripts/copy-build.mjs",
    "build": "pnpm run build:frontend && pnpm run build:copy && pnpm run build:data",
    "dev": "cd website && pnpm run dev",
    "start": "pnpm run fetch-data && pnpm run build",
    "lint": "eslint crawler --ext .ts --quiet",
    "lint:fix": "eslint crawler --ext .ts --fix",
    "format": "prettier --write \"crawler/**/*.ts\" \"**/*.md\" \"**/*.json\" && cd crawler && uv run ruff format . && uv run ruff check . --fix",
    "format:check": "prettier --check \"crawler/**/*.ts\" \"**/*.md\" \"**/*.json\"",
    "format:lint": "pnpm run format && pnpm run lint"
  },
  "keywords": [],
  "author": "tonyc726<zhujf620@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@actions/core": "^1.9.0",
    "@types/lodash": "^4.14.178",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^5.10.1",
    "@typescript-eslint/parser": "^5.10.1",
    "date-fns": "^2.30.0",
    "dotenv": "^17.0.0",
    "eslint": "^8.7.0",
    "eslint-config-alloy": "^5.1.0",
    "file-type": "^18.0.0",
    "imagekit": "^4.0.0",
    "lodash": "^4.17.21",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "sqlite3": "^5.1.7",
    "ts-node": "^10.9.0",
    "typeorm": "^0.3.20",
    "typescript": "^5.4.0"
  }
}
